<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:keepScreenOn="true">

    <!-- Vídeo fullscreen. A faixa branca e o card flutuante ficam por cima
         (overlay), sem alterar o aspect ratio do vídeo. -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fit"
        app:surface_type="surface_view"
        app:use_controller="false"
        app:show_buffering="never" />

    <!-- ============================================================ -->
    <!-- FAIXA INFERIOR (sempre visível): logo + histórico de chamadas -->
    <!-- Altura ajustada em runtime para 12% da tela (MainActivity).   -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/panel_bg">

        <!-- Logo da clínica (~22% da largura) -->
        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="22"
            android:paddingStart="32dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="Oftalmocenter"
            android:src="@drawable/logo_oftalmocenter" />

        <!-- Divisor vertical fino em accent -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/divider_accent" />

        <!-- Lado direito: header + lista -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="78"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textSize="13sp"
                android:textColor="@color/brand_primary"
                android:letterSpacing="0.20"
                android:text="ÚLTIMAS CHAMADAS" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <!-- Lista de 3 entradas. Visibilidade controlada em código.
                 Fonte 17sp deliberadamente menor que o card central — esta
                 região tem espaço vertical reduzido (12% da tela ÷ 3 rows). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/history_row_1"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/history_name_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/history_room_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="16dp"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/history_row_2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/history_name_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/history_room_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="16dp"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/history_row_3"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/history_name_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/history_room_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-light"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="16dp"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- CARD FLUTUANTE — só visível durante chamada                  -->
    <!-- Centralizado verticalmente um pouco acima do meio.           -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/call_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="40dp"
        android:orientation="vertical"
        android:gravity="start"
        android:paddingStart="64dp"
        android:paddingEnd="64dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp"
        android:background="@drawable/card_bg"
        android:elevation="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:id="@+id/card_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textSize="20sp"
            android:textColor="@color/brand_primary"
            android:letterSpacing="0.30"
            android:includeFontPadding="false"
            android:text="ATENÇÃO PACIENTE" />

        <TextView
            android:id="@+id/call_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textSize="44sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="14dp"
            android:lineSpacingMultiplier="0.95"
            android:includeFontPadding="false"
            android:text="—" />

        <View
            android:layout_width="72dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/divider_accent" />

        <TextView
            android:id="@+id/call_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textSize="28sp"
            android:textColor="@color/brand_primary"
            android:visibility="visible"
            android:includeFontPadding="false"
            android:text="—" />
    </LinearLayout>

</FrameLayout>
