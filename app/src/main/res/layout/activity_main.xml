<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fit"
        app:surface_type="surface_view"
        app:use_controller="false"
        app:show_buffering="never" />

    <!-- ESTADO IDLE: barra discreta no rodapé direito (relógio + logo). -->
    <LinearLayout
        android:id="@+id/idle_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/overlay_bg_dim">

        <TextView
            android:id="@+id/idle_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:textSize="22sp"
            android:textColor="@color/overlay_muted"
            android:text="00:00" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/overlay_muted"
            android:alpha="0.4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textSize="16sp"
            android:textColor="@color/overlay_muted"
            android:letterSpacing="0.18"
            android:text="OFTALMOCENTER" />
    </LinearLayout>

    <!-- ESTADO CHAMANDO: painel grande no rodapé com nome e sala. -->
    <LinearLayout
        android:id="@+id/call_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp"
        android:background="@color/overlay_bg_solid"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textSize="20sp"
            android:textColor="@color/overlay_accent"
            android:letterSpacing="0.30"
            android:text="ATENÇÃO, PACIENTE"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/call_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textSize="60sp"
            android:textColor="@color/overlay_text_primary"
            android:gravity="center"
            android:text="—"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/call_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textSize="34sp"
            android:textColor="@color/overlay_text_secondary"
            android:gravity="center"
            android:text="—" />
    </LinearLayout>

</FrameLayout>
